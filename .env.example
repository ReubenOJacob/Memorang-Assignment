# ─── LLM provider ────────────────────────────────────────────────────────────
# Default provider is OpenAI. Set MODEL_PROVIDER=anthropic to use Claude instead.
MODEL_PROVIDER=openai

# OpenAI (default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (only used when MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ─── Persistence ─────────────────────────────────────────────────────────────
# When true: use in-memory checkpointer + in-state attempts (no Docker/Postgres needed).
# When false: use Postgres for the LangGraph checkpointer AND the attempts ledger.
USE_MEMORY_SAVER=true

# Only used when USE_MEMORY_SAVER=false
DATABASE_URL=postgresql://lesson:lesson@localhost:5432/lesson

# ─── Wiring ──────────────────────────────────────────────────────────────────
# URL where the LangGraph agent dev server is reachable (used by the web runtime route).
LANGGRAPH_URL=http://localhost:8123

# Graph id, must match the key in agent/langgraph.json
LANGGRAPH_AGENT_ID=lesson_agent

# ─── Optional: tracing ───────────────────────────────────────────────────────
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=pdf-lesson-agent
